# Application Settings
APP_NAME="Mutual Fund FAQ Assistant"
APP_VERSION="1.0.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# LLM Configuration (choose one)
# Option 1: OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Option 2: Groq (recommended - fast & cheap)
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama3-8b-8192
LLM_PROVIDER=groq

# Local Embeddings Configuration (Free)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/vector_store
CHROMA_COLLECTION_NAME=mutual_fund_docs

# Database Configuration
DATABASE_URL=sqlite:///./data/chat_history.db

# Security Settings
MAX_QUERY_LENGTH=500
RATE_LIMIT_PER_MINUTE=30
SECRET_KEY=your-secret-key-here-change-in-production

# Compliance Settings
DISCLAIMER="Facts-only. No investment advice."

# Scraping Configuration
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RATE_LIMIT_DELAY=1

# Logging
LOG_LEVEL=INFO
